# Minimal starter .env for Hermes on Windows when using xAI Grok OAuth (SuperGrok)
# Copy this to ~/.hermes/.env (or C:\Users\<you>\.hermes\.env) and adjust as needed.

# Primary inference
HERMES_INFERENCE_PROVIDER=xai-oauth
HERMES_INFERENCE_MODEL=grok-4.3

# Optional: Increase tool call timeouts if working on large tasks
# HERMES_TOOL_TIMEOUT=300

# Add other provider keys only when you actually need them (OpenRouter, Anthropic, etc.)
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...
